{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@core": ["./packages/core/index.ts"],
      "@core/*": ["./packages/core/*"]
    }
  },
  "include": ["packages/**/*", "examples/**/*"]
}
