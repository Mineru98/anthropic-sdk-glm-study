{
  "name": "anthropic-sdk-glm-study",
  "private": true,
  "type": "module",
  "scripts": {
    "orchestrator": "bun run examples/orchestrator.ts",
    "verify:orchestrator": "bun run examples/orchestrator.ts --verify",
    "agents": "bun run examples/agents/run.ts",
    "agents:list": "bun run examples/agents/run.ts list",
    "agents:tui": "bun run examples/agents/tui/index.tsx",
    "agents:demo": "bun run examples/agents/demo/record.ts",
    "agents:demo:all": "bun run examples/agents/demo/record-all.ts",
    "agents:demo:speedup": "bun run examples/agents/demo/speedup.ts",
    "agents:index": "bun run examples/agents/gen-index.ts",
    "agents:typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@anthropic-ai/sdk": "^0.104.1",
    "@inkjs/ui": "^2.0.0",
    "dotenv": "^17.3.1",
    "ink": "^7.0.6",
    "react": "^19.2.7",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "playwright": "^1.61.0"
  }
